DATABASE_URL=postgresql+asyncpg://securechat:securechat@localhost:5433/securechat
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=dev-secret-change-in-production
DEV_AUTH_BYPASS=true
SECURITY_PROFILE=pii-redact
DAILY_MESSAGE_QUOTA=100

# LLM backend: mock | bedrock | ollama | openai | auto
LLM_PROVIDER=ollama
LLM_REQUEST_TIMEOUT=120

# Auto mode: candidate backends (priority order) + selection strategy
# strategy: failover (try in order) | round_robin (balance) | random
LLM_AUTO_PROVIDERS=ollama,openai,bedrock
LLM_AUTO_STRATEGY=failover

# --- Ollama (local LLM you downloaded) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Generic OpenAI-compatible endpoint (any hosted/self-hosted LLM) ---
# Examples:
#   Groq:       OPENAI_BASE_URL=https://api.groq.com/openai/v1   OPENAI_MODEL=llama-3.3-70b-versatile
#   OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1     OPENAI_MODEL=meta-llama/llama-3-70b-instruct
#   LM Studio:  OPENAI_BASE_URL=http://localhost:1234/v1         OPENAI_MODEL=<loaded-model>
#   OpenAI:     OPENAI_BASE_URL=https://api.openai.com/v1        OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- AWS Bedrock ---
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-opus-20240229-v1:0
